# NGQ Data API — per-user key from Settings → API Keys
NGQ_API_KEY=replace-me
NGQ_BASE_URL=https://analysis-api.opessemper.com/
NGQ_SERIES=GCQ6

# Local bridge
BRIDGE_PORT=8787
POLL_INTERVAL_MS=30000

# Launcher (macOS: /Applications/TradingView.app, Windows: %LOCALAPPDATA%\TradingView\TradingView.exe)
TV_APP_PATH=/Applications/TradingView.app
CDP_PORT=9222

# Pine input.text_area title (default: NGQ Data)
TVMONKEY_INPUT_TITLE=NGQ Data
